{
  "version": 2,
  "outputDirectory": "frontend",
  "buildCommand": "echo 'static only'",
  "installCommand": "echo 'no install'",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": { "Content-Type": "application/json" },
      "dest": "/api-unavailable.json"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
